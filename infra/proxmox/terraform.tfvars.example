proxmox_endpoint  = "https://<proxmox-host>:8006/"
proxmox_api_token = "<user>@<realm>!<token-name>=<token-secret>"
proxmox_insecure  = true

proxmox_node_name = "<proxmox-node-name>"

image_datastore_id = "<image-datastore-id>"
vm_datastore_id    = "<vm-datastore-id>"
network_bridge     = "<network-bridge-name>"

dns_servers = ["<dns-server-ip>"]

qemu_guest_agent_enabled = false

# The default image is pinned to a specific Ubuntu 24.04 release artifact.
# Change both the URL and checksum together if you intentionally move to a newer image.
ubuntu_cloud_image_url      = "https://cloud-images.ubuntu.com/releases/noble/release-20260518/ubuntu-24.04-server-cloudimg-amd64.img"
ubuntu_cloud_image_checksum = "53fdde898feed8b027d94baa9cfe8229867f330a1d9c49dc7d84465ee7f229f7"
# ubuntu_cloud_image_file_name_override = "custom-image.qcow2"

template_vm_id       = 9000
template_name        = "ubuntu-2404-cloudinit"
template_description = "Ubuntu 24.04 LTS cloud-init template"

# Supported cluster shape: exactly one control-plane node and one or more workers.
# To change worker count, add or remove worker entries here and in ansible/inventory/homelab.ini.
# Set DHCP reservations for these MAC addresses, or otherwise ensure each node gets its reserved_ip.
# CPU, memory, and disk are intentionally configurable per node.
kubernetes_nodes = {
  k8s-cp-01 = {
    vm_id        = 101
    role         = "control-plane"
    mac_address  = "02:00:00:00:10:01"
    reserved_ip  = "<reserved-ip-for-k8s-cp-01>"
    cpu_cores    = 2
    memory_mb    = 4096
    disk_size_gb = 40
  }

  k8s-worker-01 = {
    vm_id        = 111
    role         = "worker"
    mac_address  = "02:00:00:00:10:11"
    reserved_ip  = "<reserved-ip-for-k8s-worker-01>"
    cpu_cores    = 2
    memory_mb    = 4096
    disk_size_gb = 40
  }

  k8s-worker-02 = {
    vm_id        = 112
    role         = "worker"
    mac_address  = "02:00:00:00:10:12"
    reserved_ip  = "<reserved-ip-for-k8s-worker-02>"
    cpu_cores    = 2
    memory_mb    = 4096
    disk_size_gb = 40
  }
}
